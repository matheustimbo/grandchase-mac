#!/bin/zsh
# Abre o Grand Chase (Steam app 985810) na bottle do CrossOver.
# Config vencedora: bottle CrossOver + Steam logada + renderer nativo (wined3d/D3DMetal)
# Themida resolvido via overrides native dos runtimes VC++ no registro da bottle.
#
# Uso:
#   grandchase          -> abre o jogo (sobe a Steam se preciso)
#   grandchase steam    -> abre so o cliente Steam da bottle
#   grandchase kill     -> fecha tudo (Steam + jogo)

CX="/Applications/CrossOver.app/Contents/SharedSupport/CrossOver"
BOTTLE="Steam"
STEAM='C:\Program Files (x86)\Steam\Steam.exe'
CONNLOG="$HOME/Library/Application Support/CrossOver/Bottles/Steam/drive_c/Program Files (x86)/Steam/logs/connection_log.txt"

# Steam "de pe" = webhelper OU Steam.exe rodando (webhelper indica que ja logou)
steam_up() { pgrep -f "steamwebhelper.exe" >/dev/null 2>&1 || pgrep -f "[S]team.exe" >/dev/null 2>&1; }

launch_game() { "$CX/bin/cxstart" --bottle "$BOTTLE" "$STEAM" -applaunch 985810 >/dev/null 2>&1 & }

case "$1" in
  kill)
    pkill -9 -f "[S]team.exe|[s]teamwebhelper|[G]randChase" 2>/dev/null
    echo "GrandChase/Steam encerrados"
    ;;
  steam)
    "$CX/bin/cxstart" --bottle "$BOTTLE" "$STEAM"
    ;;
  *)
    if steam_up; then
      echo "Steam ja aberta — abrindo o GrandChase..."
      launch_game
    else
      echo "Subindo a Steam (login)..."
      "$CX/bin/cxstart" --bottle "$BOTTLE" "$STEAM" -silent >/dev/null 2>&1 &
      # espera o webhelper subir (Steam pronta) + logar — no maximo ~45s
      ok=0
      for i in $(seq 1 45); do
        sleep 1
        if steam_up && [ -n "$(find "$CONNLOG" -newermt '-40 seconds' 2>/dev/null)" ] \
           && grep -q "Logged On" "$CONNLOG" 2>/dev/null; then ok=1; break; fi
      done
      [ "$ok" = 1 ] && echo "Steam logada — abrindo o GrandChase..." || echo "(login demorou; abrindo mesmo assim)"
      launch_game
    fi
    echo "Pronto. O jogo abre em alguns segundos (passa por loading)."
    ;;
esac
