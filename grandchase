#!/bin/zsh
# GrandChase 100% GRÁTIS no macOS (sem CrossOver) — wine-proton (wined3d → OpenGL → Metal)
# Só precisa do wine-proton: ele traz o wined3d, o caminho GL→Metal e o MoltenVK embutido.
# (DXVK/MoltenVK-override NÃO são usados — ver README. Verificado: M1 Max, macOS 27.)
#
#   grandchase        -> sobe a Steam (login) e abre o jogo
#   grandchase steam  -> abre só a Steam (pra logar / ver biblioteca)
#   grandchase kill   -> fecha tudo

WP="$HOME/Games/wine-proton"
WINE="$WP/bin/wine"
PFX="$HOME/Games/gc-proton"
STEAM='C:\Program Files (x86)\Steam\steam.exe'
CONNLOG="$PFX/drive_c/Program Files (x86)/Steam/logs/connection_log.txt"

export WINEPREFIX="$PFX"
export WINEDEBUG=-all
export DYLD_FALLBACK_LIBRARY_PATH="$WP/lib:$WP/lib/wine/x86_64-unix"
export WINEESYNC=1
export WINEENGINE_GPTK_DXGI_SPOOF_ENABLED=1

steam_up() { pgrep -f "steamwebhelper.exe" >/dev/null 2>&1 || pgrep -f "[s]team.exe" >/dev/null 2>&1; }

case "$1" in
  kill)
    pkill -9 -f "[s]team.exe|steamwebhelper|[G]randChase" 2>/dev/null
    "$WP/bin/wineserver" -k 2>/dev/null
    echo "GrandChase/Steam encerrados"
    ;;
  steam)
    "$WINE" "$STEAM"
    ;;
  *)
    if ! steam_up; then
      echo "Subindo a Steam (login)..."
      "$WINE" "$STEAM" -silent >/dev/null 2>&1 &
      for i in $(seq 1 24); do
        sleep 3
        grep -E "$(date '+%Y-%m-%d %H')" "$CONNLOG" 2>/dev/null | grep -qiE "RecvMsgClientLogOnResponse" && break
      done
    fi
    echo "Abrindo o GrandChase..."
    "$WINE" "$STEAM" -applaunch 985810 >/dev/null 2>&1 &
    echo "Pronto. Passa pelo loading e entra no lobby."
    ;;
esac
